# MasterConnect Environment Configuration

# === Основные настройки ===
APP_ENV=development
APP_NAME=MasterConnect API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-here-change-in-production
API_PREFIX=/api/v1

# === JWT настройки ===
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30

# === База данных ===
# Для локального MVP используем SQLite (без Docker)
DATABASE_URL=sqlite+aiosqlite:///./apps/api/test.db
DATABASE_ECHO=false

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === CORS ===
# Включаем Vite dev server
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# === Файловое хранилище (S3) ===
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=masterconnect-files
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_REGION=us-east-1

# === Email ===
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=apikey
EMAIL_SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@masterconnect.kz
EMAIL_USE_TLS=true

# === Google Calendar ===
# Включить интеграцию с Google Calendar
GOOGLE_CALENDAR_ENABLED=false

# Путь к JSON файлу Service Account (для разработки)
# Пример: GOOGLE_SERVICE_ACCOUNT_FILE=C:/path/to/service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=

# ИЛИ base64-encoded JSON (для production, безопаснее)
# Пример: GOOGLE_SERVICE_ACCOUNT_JSON_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# ID календаря (email владельца или специальный ID)
# Для личного календаря: ваш email (например: user@gmail.com)
# Для календаря Google Workspace: email или calendar ID
# Если не указан, используется 'primary' (основной календарь)
GOOGLE_CALENDAR_ID=

# Делегированный пользователь (только для Google Workspace)
# Позволяет Service Account действовать от имени указанного пользователя
# GOOGLE_CALENDAR_DELEGATED_USER=mentor@yourdomain.com

# === Kaspi платежи ===
KASPI_PAYMENT_URL=https://pay.kaspi.kz/your-payment-link

# === Уведомления ===
REMINDER_24H_ENABLED=true
REMINDER_1H_ENABLED=true

# === Rate limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# === Настройки загрузки файлов ===
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,docx

# === Настройки брони ===
BOOKING_HOLD_DURATION_MINUTES=10

