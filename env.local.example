# MasterConnect Local Development Environment Configuration
# Скопируй этот файл в .env для локальной разработки

# === Основные настройки ===
APP_ENV=development
APP_NAME=MasterConnect API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=<СГЕНЕРИРУЙ: openssl rand -hex 32>
API_PREFIX=/api/v1

# === JWT настройки ===
JWT_SECRET_KEY=<СГЕНЕРИРУЙ: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30

# === База данных PostgreSQL (для Docker) ===
# Для локальной разработки используем PostgreSQL из docker-compose
# Важно: используем localhost, так как API запускается на хосте, а не в контейнере
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/masterconnect
POSTGRES_DB=masterconnect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_ECHO=false

# === Redis (для Docker) ===
REDIS_URL=redis://localhost:6379/0

# === CORS ===
# Для локальной разработки разрешаем localhost
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# === Файловое хранилище (S3) - НЕ ИСПОЛЬЗУЕТСЯ, можно оставить пустым ===
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# === Email (SendGrid) - НЕ ИСПОЛЬЗУЕТСЯ, можно оставить пустым ===
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=apikey
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=noreply@mastereducation.kz
EMAIL_USE_TLS=true

# === Google Calendar ===
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_CALENDAR_ID=

# === Kaspi платежи ===
KASPI_PAYMENT_URL=https://pay.kaspi.kz/pay/default

# === Уведомления ===
REMINDER_24H_ENABLED=true
REMINDER_1H_ENABLED=true

# === Rate limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# === Настройки загрузки файлов ===
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,docx

# === Настройки брони ===
BOOKING_HOLD_DURATION_MINUTES=30

# === Docker порты ===
API_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# === Фронтенд переменные (для сборки React) ===
# Для локальной разработки используем localhost
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

